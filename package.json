{
  "name": "mdpreview",
  "version": "0.1.1",
  "description": "A quiet Windows desktop Markdown editor inspired by Typora.",
  "main": "out/main/index.js",
  "author": "MdPreview",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "npm run dist:installer",
    "dist:dir": "npm run build && electron-builder --win --dir",
    "dist:installer": "npm run build && electron-builder --win nsis",
    "dist:portable": "npm run build && electron-builder --win portable",
    "dist:zip": "npm run build && electron-builder --win zip",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "@highlightjs/cdn-assets": "^11.11.1",
    "dompurify": "^3.2.6",
    "markdown-it": "^14.1.0",
    "markdown-it-task-lists": "^2.1.1",
    "vditor": "^3.11.2",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "electron": "^41.3.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.mdpreview.app",
    "productName": "MdPreview",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown",
          "mdown",
          "mkd"
        ],
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
